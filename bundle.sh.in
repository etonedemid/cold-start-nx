#!/bin/sh
# ─── Linux Distribution Bundle ──────────────────────────────────────────────
# Auto-generated by CMake from bundle.sh.in
# Bundles the PC build into a self-contained dist/ folder
# ─────────────────────────────────────────────────────────────────────────────
set -e

SRC_EXE="@CMAKE_BINARY_DIR@/cold_start"
ROMFS_SRC="@CMAKE_SOURCE_DIR@/romfs"
DIST="@CMAKE_BINARY_DIR@/dist"

echo "==> Creating bundle in $DIST"
rm -rf "$DIST"
mkdir -p "$DIST/libs"

# Copy executable and assets
cp "$SRC_EXE" "$DIST/cold_start"
chmod +x "$DIST/cold_start"
cp -r "$ROMFS_SRC/." "$DIST/romfs/"

# ── Shared library bundling ─────────────────────────────────────────────────
# Bundle all non-system .so files. We deliberately EXCLUDE glibc (libc.so.6,
# libpthread, libm, libdl, ld-linux, libgcc_s, libstdc++) because:
#   - glibc is ABI‑forward-compatible: any distro with glibc >= the build
#     version runs the binary fine with its own glibc.
#   - Mixing a bundled ld-linux with the system's libc (or vice-versa) causes
#     SIGSEGV or symbol-lookup failures since they must come from the same build.

is_glibc() {
    case "$1" in
        */ld-linux*|*/ld-musl*) return 0 ;;
        */libc.so*|*/libc-[0-9]*) return 0 ;;
        */libpthread*|*/libdl*|*/librt.so*) return 0 ;;
        */libm.so*|*/libm-[0-9]*) return 0 ;;
        */libgcc_s*|*/libstdc++*) return 0 ;;
        */libgomp*|*/libasan*) return 0 ;;
    esac
    return 1
}

copy_deps() {
    ldd "$1" 2>/dev/null | grep -oE '/[^ ]+\.so[^ ]*' | while read -r lib; do
        is_glibc "$lib" && continue
        base="$(basename "$lib")"
        if [ ! -f "$DIST/libs/$base" ]; then
            cp -Lv "$lib" "$DIST/libs/$base" 2>/dev/null || true
        fi
    done
}

# Seed from the main executable
copy_deps "$DIST/cold_start"

# Iterate until stable (handles transitive deps)
changed=1
while [ "$changed" = "1" ]; do
    changed=0
    for so in "$DIST/libs/"*.so*; do
        [ -f "$so" ] || continue
        before=$(ls "$DIST/libs/" | wc -l)
        copy_deps "$so"
        after=$(ls "$DIST/libs/" | wc -l)
        [ "$after" -gt "$before" ] && changed=1
    done
done

# If SDL2 is sdl2-compat, it needs SDL3 at runtime
for sdl3lib in /usr/lib/libSDL3.so* /usr/lib/libSDL3_*.so*; do
    [ -f "$sdl3lib" ] || continue
    base="$(basename "$sdl3lib")"
    [ -f "$DIST/libs/$base" ] && continue
    is_glibc "$sdl3lib" && continue
    cp -Lv "$sdl3lib" "$DIST/libs/$base" 2>/dev/null || true
done

for so in "$DIST/libs/"libSDL3*.so*; do
    [ -f "$so" ] || continue
    copy_deps "$so"
done

# Copy SDL2_mixer audio decoder plugins
for d in \
    /usr/lib/x86_64-linux-gnu/SDL2 \
    /usr/lib/aarch64-linux-gnu/SDL2 \
    /usr/lib/SDL2 \
    /usr/local/lib/SDL2; do
    if [ -d "$d" ]; then
        cp -L "$d"/*.so* "$DIST/libs/" 2>/dev/null || true
    fi
done

# ── Explicit fallback for libs ldd shows as "not found" ─────────────────────
for libname in libminiupnpc.so; do
    base=$(ldconfig -p 2>/dev/null | awk -v n="$libname" '$1 ~ n {print $NF; exit}')
    if [ -z "$base" ]; then
        for d in \
            /usr/lib/x86_64-linux-gnu \
            /usr/lib/aarch64-linux-gnu \
            /usr/lib \
            /usr/local/lib; do
            found=$(ls "$d/${libname}"* 2>/dev/null | head -1)
            [ -n "$found" ] && base="$found" && break
        done
    fi
    if [ -n "$base" ] && [ -f "$base" ]; then
        dir=$(dirname "$base")
        stem=$(echo "$base" | sed 's/\.so.*//')
        for f in "$dir"/$(basename "$stem").so*; do
            [ -f "$f" ] || is_glibc "$f" && continue
            dest="$DIST/libs/$(basename "$f")"
            [ -f "$dest" ] || cp -Lv "$f" "$dest" 2>/dev/null || true
        done
    fi
done

# ── Launcher ────────────────────────────────────────────────────────────────
cat > "$DIST/run.sh" << 'EOF'
#!/bin/sh
cd "$(dirname "$0")"
LD_LIBRARY_PATH="$(pwd)/libs${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LD_LIBRARY_PATH
exec ./cold_start "$@"
EOF
chmod +x "$DIST/run.sh"

echo "==> Bundle ready: $DIST"
echo "    Run with: $DIST/run.sh"
ls -1 "$DIST/libs/"
