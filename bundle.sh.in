#!/bin/sh
# Auto-generated by CMake — bundles the PC build into a self-contained dist/ folder
set -e

SRC_EXE="@CMAKE_BINARY_DIR@/cold_start"
ROMFS_SRC="@CMAKE_SOURCE_DIR@/romfs"
DIST="@CMAKE_BINARY_DIR@/dist"

echo "==> Creating bundle in $DIST"
mkdir -p "$DIST/libs"

# Copy executable
cp "$SRC_EXE" "$DIST/cold_start"

# Copy romfs assets
cp -r "$ROMFS_SRC/." "$DIST/romfs/"

# Copy shared libraries recursively:
# Start from the executable, then keep scanning newly-copied .so files
# until no new dependencies are discovered.
# NOTE: All glibc libs (libc, libm, libpthread, etc.) and ld-linux ARE bundled
# Only exclude C++ runtime libs (usually compatible across distros)
copy_deps() {
  ldd "$1" 2>/dev/null | grep -oE '/[^ ]+\.so[^ ]*' | while read -r lib; do
    case "$lib" in
      */libgcc_s*|*/libstdc++*) continue ;;
    esac
    base="$(basename "$lib")"
    if [ ! -f "$DIST/libs/$base" ]; then
      cp -Lv "$lib" "$DIST/libs/$base" 2>/dev/null || true
    fi
  done
}

# Seed from the main executable
copy_deps "$DIST/cold_start"

# Iterate until stable (handles transitive deps like libjxl → libhwy, libbrotli, etc.)
changed=1
while [ "$changed" = "1" ]; do
  changed=0
  for so in "$DIST/libs/"*.so*; do
    [ -f "$so" ] || continue
    before=$(ls "$DIST/libs/" | wc -l)
    copy_deps "$so"
    after=$(ls "$DIST/libs/" | wc -l)
    [ "$after" -gt "$before" ] && changed=1
  done
done

# If SDL2 is actually sdl2-compat, it needs SDL3 at runtime
# Copy SDL3 libs if present (sdl2-compat dynamically loads them)
for sdl3lib in /usr/lib/libSDL3.so* /usr/lib/libSDL3_*.so*; do
  [ -f "$sdl3lib" ] || continue
  base="$(basename "$sdl3lib")"
  if [ ! -f "$DIST/libs/$base" ]; then
    cp -Lv "$sdl3lib" "$DIST/libs/$base" 2>/dev/null || true
  fi
done

# Recursively copy SDL3 dependencies
for so in "$DIST/libs/"libSDL3*.so*; do
  [ -f "$so" ] || continue
  copy_deps "$so"
done

# Copy SDL2_mixer audio decoder plugins if bundled as separate .so files
for d in \
  /usr/lib/x86_64-linux-gnu/SDL2 \
  /usr/lib/aarch64-linux-gnu/SDL2 \
  /usr/lib/SDL2 \
  /usr/local/lib/SDL2; do
  if [ -d "$d" ]; then
    cp -L "$d"/*.so* "$DIST/libs/" 2>/dev/null || true
  fi
done

# Write launcher that uses bundled glibc/loader if present, otherwise system ones
cat > "$DIST/run.sh" << 'EOF'
#!/bin/sh
cd "$(dirname "$0")"

# Use bundled dynamic linker if present (for glibc portability)
LOADER=$(ls ./libs/ld-linux*.so* 2>/dev/null | head -1)
if [ -n "$LOADER" ] && [ -f "$LOADER" ]; then
  exec "$LOADER" --library-path ./libs ./cold_start "$@"
else
  # Fallback to LD_LIBRARY_PATH if no bundled loader
  LD_LIBRARY_PATH=./libs:${LD_LIBRARY_PATH}
  export LD_LIBRARY_PATH
  exec ./cold_start "$@"
fi
EOF
chmod +x "$DIST/run.sh"

echo "==> Bundle ready: $DIST"
echo "    Run with: $DIST/run.sh"
ls -1 "$DIST/libs/"
